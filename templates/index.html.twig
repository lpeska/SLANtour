{% extends "_base.html.twig" %}

{% block meta %}
<meta name="description" content="SLANtour - Cestovní kancelář s více než 30letou tradicí. Nabízíme poznávací zájezdy, lázně, dovolenou u moře a sportovní zájezdy.">
<meta name="keywords" content="poznávací zájezdy, lázně, dovolená u moře, sportovní zájezdy, cestovní kancelář, SLANtour">
{% endblock meta %}

{% block title %}SLANtour | Poznávací zájezdy, lázně, dovolená u moře a sportovní zájezdy{% endblock title %}

{% block main %}

<section class="home-hero" aria-labelledby="home-hero-title">
	<div class="home-hero__overlay" aria-hidden="true"></div>
	<div class="home-hero__content">
		<p class="home-hero__eyebrow">CESTOVNÍ KANCELÁŘ OD ROKU 1990</p>
			<h1 id="home-hero-title">
				Dovolená u moře, poznávací zájezdy, eurovíkendy, lázně i sportovní zájezdy.
			</h1>

			<p class="home-hero__lead">
			CK SLAN tour již přes {{ yearsSinceFounded }} let plní vaše cestovatelské sny.
		</p>
		<ul class="home-hero__trust" aria-label="Důvody proč cestovat se SLANtour">
			<li>
				<i class="fa-solid fa-medal" aria-hidden="true"></i>
				<span>{{ yearsSinceFounded }} let tradice</span>
			</li>
			<li>
				<i class="fa-solid fa-suitcase-rolling" aria-hidden="true"></i>
				<span>{{ totalTours }} zájezdů</span>
			</li>
			<li>
				<i class="fa-solid fa-users" aria-hidden="true"></i>
				<span>245 000+ klientů</span>
			</li>
			<li>
				<i class="fa-solid fa-shield-halved" aria-hidden="true"></i>
				<span>Pojištění proti úpadku CK</span>
			</li>
			<li>
				<i class="fa-solid fa-certificate" aria-hidden="true"></i>
				<span>Členství v ACK</span>
			</li>
		</ul>
	</div>
</section>

<div class="main_search">
	<h3><i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i> Vyhledat zájezd</h3>
	<form action="/vyhledavani" role="search" aria-label="Vyhledávání zájezdů" class="search-form-accessible">
		<div class="custom-search-input-2 search-box-accessible search-box-horizontal">
			<input type="hidden" name="dates" id="search-dates" class="search-dates-range">
			<div class="form-group">
				<label for="search-destination" class="search-field-label">Kam chcete vycestovat?</label>
				<input class="form-control" type="search" name="txt" placeholder="Např. Itálie, Londýn, Mexiko" id="search-destination" autocomplete="off">
				<i class="fa-solid fa-location-dot" aria-hidden="true"></i>
			</div>
			<div class="form-group">
				<label for="search-date-from" class="search-field-label">Termín od</label>
				<input class="form-control search-date-boundary search-date-from" type="date" id="search-date-from" autocomplete="off">
				<i class="fa-solid fa-calendar-days" aria-hidden="true"></i>
			</div>
			<div class="form-group">
				<label for="search-date-to" class="search-field-label">Termín do</label>
				<input class="form-control search-date-boundary search-date-to" type="date" id="search-date-to" autocomplete="off">
				<i class="fa-solid fa-calendar-days" aria-hidden="true"></i>
			</div>
			<div class="form-group">
				<label for="search-tour-type" class="search-field-label">Typ zájezdu</label>
				<select name="tourTypeFilter" id="search-tour-type" class="wide" aria-label="Typ zájezdu">
					<option value="">Všechny typy</option>
					{% for tourType in typesOfTours %}
						<option value="{{ tourType.id }}">{{ tourType.name }}</option>
					{% endfor %}
				</select>
				<i class="fa-solid fa-compass" aria-hidden="true"></i>
			</div>
			<div class="form-group text-right search-submit-group">
				<button type="submit" class="btn_search" aria-label="Zobrazit nabídku zájezdů podle zadaných kritérií"><i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i> Zobrazit nabídku</button>
			</div>
		</div>
		<!-- /row -->
		<div class="search-assist">
			<strong>Nevíte přesně kam?</strong>
			<a href="/kontakty.html">Poradíme s výběrem</a>
			<span aria-hidden="true">|</span>
			<a href="tel:+420604255018">+420 604 255 018 (Po-Pá 9-17)</a>
		</div>
	</form>
</div>
<!-- /main_search -->

